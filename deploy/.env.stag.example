# ─────────────────────────────────────────────────────────────────────────────
# .env.stag — slot-control vars only
# Update STAGING_TAG when you want to pin a specific image.
#
# All secrets (DB creds, AWS keys, ADMIN_PASSCODE, etc.) live in Doppler
# under the "stg" config. Store the service token in .doppler-stag-token.
# ─────────────────────────────────────────────────────────────────────────────
STAGING_TAG=staging-latest
