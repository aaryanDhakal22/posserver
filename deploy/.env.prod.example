# ─────────────────────────────────────────────────────────────────────────────
# .env.prod — slot-control vars only
# Managed automatically by deploy.sh; edit only to force a reset.
#
# All secrets (DB creds, AWS keys, ADMIN_PASSCODE, etc.) live in Doppler
# under the "prd" config. Store the service token in .doppler-prod-token.
# ─────────────────────────────────────────────────────────────────────────────
BLUE_TAG=prod-latest
GREEN_TAG=prod-latest
BLUE_PRIORITY=100
GREEN_PRIORITY=1
